        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Match Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Match_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RES_Get_Lead_Status_Mapping</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_for_Active_and_Retired_Status_Mapping</targetReference>
            </connector>
            <label>Yes, Match Found</label>
        </rules>
    </decisions>
