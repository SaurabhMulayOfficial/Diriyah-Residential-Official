    <decisions>
        <name>Check_Notification_Type</name>
        <label>Check Notification Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SLA_Breach_Notification</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NotificationType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SLABreachNotification</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Email_To_Manager</targetReference>
            </connector>
            <label>SLA Breach Notification</label>
        </rules>
        <rules>
            <name>Opportunity_Closed_Won</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NotificationType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OpportunityWonNotification</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Custom_Notification</targetReference>
            </connector>
            <label>Opportunity Closed Won</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>LeadLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_260}, FIND(&quot;/services&quot;, {!$Api.Partner_Server_URL_260})-1)  &amp; &quot;/lightning/r/Lead/&quot; &amp;  {!LeadRecord.Id} &amp; &quot;/view&quot;</expression>
    </formulas>
    <formulas>
        <name>oppLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_260}, FIND(&quot;/services&quot;, {!$Api.Partner_Server_URL_260})-1)  &amp; &quot;/lightning/r/Opportunity/&quot; &amp;  {!opportunityRecord.Id} &amp; &quot;/view&quot;</expression>
    </formulas>
    <formulas>
        <name>oppWonNotificationBody</name>
        <dataType>String</dataType>
        <expression>&quot;opportunityRecord.Owner.Name&quot;  &amp; &quot;has closed&quot; &amp; &quot;opportunityRecord.Name&quot; &amp; &quot;worth&quot; &amp; &quot;opportunityRecord.Amount.&quot; &amp; &quot;Please review.&quot;</expression>
    </formulas>
