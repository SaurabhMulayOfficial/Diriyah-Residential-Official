<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RES_Mobile_E164_Format</fullName>
    <active>true</active>
    <errorConditionFormula>IF(AND($RecordType.DeveloperName = &quot;PersonAccount&quot;, AND(NOT(ISBLANK(PersonMobilePhone)),
NOT(REGEX(PersonMobilePhone, &quot;\\+\\d{1,3}\\d{4,14}&quot;)))), true, false)</errorConditionFormula>
    <errorDisplayField>PersonMobilePhone</errorDisplayField>
    <errorMessage>Mobile number must be in E.164 format (e.g., +1234567890)</errorMessage>
</ValidationRule>
