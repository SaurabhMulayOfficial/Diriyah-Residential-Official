<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RES_Mobile_E164_Format</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
NOT($Setup.RES_Config_Switch__c.RES_Validation_Rules_Off__c ),
OR(
$RecordType.DeveloperName = &quot;RES_Residential_Single_Buyer&quot;,
$RecordType.DeveloperName = &quot;RES_Residential_Multi_Buyer&quot;),
NOT(ISBLANK(RES_Opportunity_Mobile__c)),
NOT(REGEX(RES_Opportunity_Mobile__c, &quot;\\+\\d{1,3}\\d{4,14}&quot;))
)</errorConditionFormula>
    <errorDisplayField>RES_Opportunity_Mobile__c</errorDisplayField>
    <errorMessage>Mobile number must be in E.164 format (e.g., +1234567890)</errorMessage>
</ValidationRule>
