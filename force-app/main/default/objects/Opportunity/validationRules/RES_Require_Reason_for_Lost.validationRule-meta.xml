<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RES_Require_Reason_for_Lost</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(StageName, &quot;Closed Lost&quot;),
    ISPICKVAL(RES_Reason_for_Lost__c, &quot;&quot;)
)</errorConditionFormula>
    <errorDisplayField>RES_Reason_for_Lost__c</errorDisplayField>
    <errorMessage>Reason for lost is required when Stage is Closed Lost.</errorMessage>
</ValidationRule>
