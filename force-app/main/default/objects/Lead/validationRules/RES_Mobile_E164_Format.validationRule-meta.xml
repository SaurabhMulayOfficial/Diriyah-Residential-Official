<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RES_Mobile_E164_Format</fullName>
    <active>true</active>
    <description>Validation rule that checks if a phone number is in E.164 format</description>
    <errorConditionFormula>AND(
NOT($Setup.RES_Config_Switch__c.RES_Validation_Rules_Off__c ),
OR(
$RecordType.DeveloperName = &quot;RES_Company&quot;,
$RecordType.DeveloperName = &quot;RES_Individual&quot;),				
NOT(ISBLANK(MobilePhone)),
NOT(REGEX(MobilePhone, &quot;\\+\\d{1,3}\\d{4,14}&quot;))
)</errorConditionFormula>
    <errorDisplayField>MobilePhone</errorDisplayField>
    <errorMessage>Mobile number must be in E.164 format (e.g., +1234567890)</errorMessage>
</ValidationRule>
